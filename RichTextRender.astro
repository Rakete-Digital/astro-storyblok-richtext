---
import { richTextRender } from "./richTextRender";
import richTextHasContent from "./richTextHasContent";

const {
    content,
    className = "",
    style = {},
    except,
    resolvers,
    language,
    ...rest
}: {
    content: any;
    className?: string;
    style?: Record<string, any>;
    except?: string[];
    resolvers?: any;
    language?: string;
    [key: string]: any;
} = Astro.props;

const html = await richTextRender(content, { except, resolvers, language });
---

{
    richTextHasContent(content) && (
        <div
            class:list={["rich-text-render", className]}
            style={style}
            set:html={html}
            {...rest}
        />
    )
}

<style is:global lang="less">
    .rich-text-render.rich-text-render {
        ol,
        ul {
            margin: 0;
            padding: 0;
            list-style: none;
        }

        > ol,
        > ul {
            display: inline-block;
            max-width: 100%;
            margin: 0 0 1.5rem;
            text-align: left;
        }

        ol {
            counter-reset: rich-text-list-item;
        }

        li {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr);
            column-gap: 0.4em;
            align-items: start;
            list-style: none;
            line-height: 1.6;
        }

        li::marker {
            content: "";
        }

        li::before {
            grid-column: 1;
            line-height: inherit;
        }

        li > :not(ol):not(ul) {
            grid-column: 2;
            margin: 0;
        }

        li > ul,
        li > ol {
            grid-column: 2;
            margin-top: 0.5rem;
            padding: 0;
            text-align: left;
        }

        li + li {
            margin-top: 0.5rem;
        }

        ul > li::before {
            content: "•";
            font-weight: 700;
        }

        ul ul > li::before {
            content: "◦";
        }

        ul ul ul > li::before {
            content: "▪";
        }

        ol > li {
            counter-increment: rich-text-list-item;
        }

        ol > li::before {
            content: counter(rich-text-list-item) ".";
            font-weight: 700;
        }

        ol ol {
            counter-reset: rich-text-list-item;
        }

        ol ol > li::before {
            content: counter(rich-text-list-item, lower-alpha) ".";
        }

        ol ol ol {
            counter-reset: rich-text-list-item;
        }

        ol ol ol > li::before {
            content: counter(rich-text-list-item, lower-roman) ".";
        }

        img,
        picture,
        video,
        canvas,
        svg {
            display: inline-block;
            max-width: 100%;
        }

        blockquote {
            border-left: 1px solid #180165;
            padding: 20px 0 20px 20px;
        }

        &.subscript {
            font-size: 1.3rem !important;
            line-height: 1.8rem !important;
            margin-top: 42px;
        }

        > p:last-child {
            margin-bottom: 0;
        }

        > p:only-child {
            margin: 0;
        }
    }
</style>